# ============================================================
# AI Agent Scaffold — 环境变量说明
# 将需要设置的值填入 ai-agent-scaffold-app/env-config.properties
# 该文件已被 .gitignore 排除，不会提交
# ============================================================

# ---- AI API ----
# OpenAI / 兼容 API 的密钥（必填）
# AI_AGENT_OPENAI_API_KEY=sk-your-api-key-here
# 百度 MCP 服务 API 密钥（可选，使用百度搜索 MCP 时需要）
# AI_AGENT_MCP_API_KEY=bce-v3/your-mcp-api-key-here

# ---- MySQL 数据库 ----
#（不设置则使用 application-dev.yml 中的默认值 123456）
# MYSQL_USERNAME=root
# MYSQL_ROOT_PASSWORD=123456
# MYSQL_URL=jdbc:mysql://127.0.0.1:3306/xfg_frame_archetype?...

# ---- Redis Admin（Docker Compose 环境） ----
# REDIS_ADMIN_USER=admin
# REDIS_ADMIN_PASSWORD=admin
